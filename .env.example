# Public URL after deploy (Vercel) — used for desktop installer + sharing the app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# TAURI_WEB_URL=https://your-app.vercel.app

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# New Supabase projects may call this the publishable key. Either name works in the app.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — Users/Settings APIs (never expose to browser; no NEXT_PUBLIC_ prefix)
# Supabase → Settings → API Keys → Secret key (sb_secret_…) OR Legacy → service_role (eyJ…)
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=   # optional alias if you prefer this name on Vercel

# Cron / vessel sync — required for GET /api/vessel-tracking/sync (deny-all if unset)
# CRON_SECRET=generate-a-long-random-string

# Optional: apply SQL migrations locally (Dashboard → Settings → Database → password)
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-west-1
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
